# syntax=docker/dockerfile:1
FROM ubuntu:24.04

# Tiny Tapeout / SKY130 environment
ENV DEBIAN_FRONTEND=noninteractive
ENV PDK_ROOT=/ttsetup/pdk
ENV PDK=sky130A

# LibreLane version — update to match tt-gds-action/action.yml
ARG LIBRELANE_TAG=3.0.0

# Activate the Python venv for all shells and processes
ENV VIRTUAL_ENV=/ttsetup/venv
ENV PATH="/ttsetup/venv/bin:$PATH"

# System packages: simulators, build tools, and Python
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates git curl make python3 python3-dev python3-venv iverilog verilator libcairo2-dev librsvg2-bin pngquant docker.io iptables fuse-overlayfs \
    && rm -rf /var/lib/apt/lists/*

# Python venv + dependencies (cocotb, tt-support-tools requirements, librelane)
RUN mkdir -p /ttsetup
RUN python3 -m venv /ttsetup/venv
RUN --mount=type=bind,source=test/requirements.txt,target=/tmp/test_requirements.txt \
    --mount=type=cache,target=/root/.cache/pip \
    /ttsetup/venv/bin/pip install -r /tmp/test_requirements.txt
RUN --mount=type=cache,target=/root/.cache/pip \
    curl -fsSL https://raw.githubusercontent.com/TinyTapeout/tt-support-tools/main/requirements.txt | \
    /ttsetup/venv/bin/pip install -r /dev/stdin
RUN --mount=type=cache,target=/root/.cache/pip \
    /ttsetup/venv/bin/pip install librelane==${LIBRELANE_TAG}

# Verible: Verilog linter and formatter
RUN curl -L https://github.com/chipsalliance/verible/releases/download/v0.0-4053-g89d4d98a/verible-v0.0-4053-g89d4d98a-linux-static-x86_64.tar.gz | \
    tar -xzf - -C /usr/local --strip-components=1

# Setup docker-in-docker
RUN update-alternatives --set iptables /usr/sbin/iptables-legacy && \
    update-alternatives --set ip6tables /usr/sbin/ip6tables-legacy
COPY .devcontainer/docker-init.sh /usr/local/share/docker-init.sh
RUN chmod +x /usr/local/share/docker-init.sh